# Postgres connection string
# Auto-configured in docker-compose.yml; only set manually for custom deployments
DATABASE_URL=postgres://xreader:xreader@postgres:5432/xreader?sslmode=disable

# Session signing secret (required)
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# GitHub OAuth (optional here — can be configured via Setup Wizard on first run)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Fixed setup token (optional — auto-generated and printed to logs if unset)
# SETUP_TOKEN=

# Custom encryption key for stored secrets (optional — auto-generated if unset)
# XREADER_AI_ENCRYPTION_KEY=

# Google Analytics for the web app (optional, runtime).
# When set, the server injects gtag.js into served HTML and widens the CSP to
# allow it — no frontend rebuild needed. Leave unset for self-hosting; no
# analytics or phone-home of any kind is included by default.
# XREADER_GA_ID=G-XXXXXXXXXX

# Misc
LOG_LEVEL=info
TZ=Asia/Shanghai
